<model>
    <mount>//OPNsense/beepselector</mount>
    <description>
        OPNsense Beep Selector - Custom startup and shutdown beep sounds
    </description>
    <items>
        <general>
            <Enabled type="BooleanField">
                <Default>1</Default>
                <Required>Y</Required>
            </Enabled>
            <StartBeep type="OptionField">
                <Default>default</Default>
                <Required>Y</Required>
                <OptionValues>
                    <default>Default</default>
                    <short>Short</short>
                    <musical>Musical</musical>
                    <none>None (silent)</none>
                    <custom>Custom file</custom>
                </OptionValues>
            </StartBeep>
            <StopBeep type="OptionField">
                <Default>default</Default>
                <Required>Y</Required>
                <OptionValues>
                    <default>Default</default>
                    <short>Short</short>
                    <musical>Musical</musical>
                    <none>None (silent)</none>
                    <custom>Custom file</custom>
                </OptionValues>
            </StopBeep>
            <StartBeepCustom type="TextField">
                <Required>N</Required>
                <Mask>/^[a-zA-Z0-9._\-\/]*$/</Mask>
                <ValidationMessage>Please specify a valid file path (alphanumeric, dots, dashes, underscores, slashes only)</ValidationMessage>
            </StartBeepCustom>
            <StopBeepCustom type="TextField">
                <Required>N</Required>
                <Mask>/^[a-zA-Z0-9._\-\/]*$/</Mask>
                <ValidationMessage>Please specify a valid file path (alphanumeric, dots, dashes, underscores, slashes only)</ValidationMessage>
            </StopBeepCustom>
        </general>
    </items>
</model>
